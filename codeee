local function C_1b()
local script = G2L["1b"];
	-- ==========================================
	-- MM2_AutoFarm (С ОСТАНОВКОЙ ПО ЗАПОЛНЕНИЮ МЕШКА)
	-- ==========================================
	local button = script.Parent
	local player = game.Players.LocalPlayer
	local runService = game:GetService("RunService")
	
	local isEnabled = false
	local farmLoop = nil
	local isFarming = false
	local waitingForRespawn = false
	local lastTeleportTime = 0
	local collectedCoins = 0
	local maxCoins = 40 -- лимит монет в мешке
	
	-- Индикатор
	local indicator = Instance.new("TextLabel")
	indicator.Name = "Indicator"
	indicator.Size = UDim2.new(1, 0, 0.3, 0)
	indicator.Position = UDim2.new(0, 0, 0.7, 0)
	indicator.BackgroundTransparency = 1
	indicator.Text = "ВЫКЛ"
	indicator.TextColor3 = Color3.fromRGB(255, 0, 0)
	indicator.TextSize = 14
	indicator.Font = Enum.Font.SourceSansBold
	indicator.Parent = button
	
	local function updateState()
		if isEnabled then
			if waitingForRespawn then
				indicator.Text = "ОЖИДАНИЕ"
				indicator.TextColor3 = Color3.fromRGB(255, 255, 0)
			else
				indicator.Text = "ФАРМ " .. collectedCoins .. "/" .. maxCoins
				indicator.TextColor3 = Color3.fromRGB(0, 255, 0)
			end
		else
			indicator.Text = "ВЫКЛ"
			indicator.TextColor3 = Color3.fromRGB(255, 0, 0)
		end
	end
	
	-- ===== ПРОВЕРКА: ЖИВ ЛИ ИГРОК =====
	local function isAlive()
		local char = player.Character
		if not char then return false end
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if not humanoid then return false end
		return humanoid.Health > 0
	end
	
	-- ===== ПОЛУЧЕНИЕ КОЛИЧЕСТВА МОНЕТ В МЕШКЕ =====
	local function getCoinCount()
		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats then
			local coins = leaderstats:FindFirstChild("Coins")
			if coins then
				return coins.Value
			end
		end
		return 0
	end
	
	-- ===== ПОИСК БЛИЖАЙШЕЙ НЕ СОБРАННОЙ МОНЕТЫ =====
	local function findNearestCoin()
		local char = player.Character
		if not char then return nil end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return nil end
	
		local nearestCoin = nil
		local nearestDist = math.huge
	
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name == "Coin_Server" then
				local dist = (hrp.Position - obj.Position).Magnitude
	
				-- Пропускаем монеты, которые уже собраны (расстояние < 2)
				if dist < 2 then
					continue
				end
	
				if dist < nearestDist then
					nearestDist = dist
					nearestCoin = obj
				end
			end
		end
	
		return nearestCoin
	end
	
	-- ===== ТЕЛЕПОРТ К МОНЕТЕ =====
	local function teleportToCoin(coin)
		local char = player.Character
		if not char then return end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		hrp.CFrame = CFrame.new(coin.Position + Vector3.new(0, 3, 0))
	end
	
	-- ===== ОСНОВНОЙ ЦИКЛ =====
	local function farmLoopFunction()
		if not isEnabled then return end
	
		if not isAlive() then
			if not waitingForRespawn then
				waitingForRespawn = true
				updateState()
				print("💀 Мёртв, жду перерождения...")
			end
			return
		end
	
		if waitingForRespawn then
			waitingForRespawn = false
			updateState()
			print("🔄 Переродился!")
		end
	
		-- Проверяем количество монет
		local coins = getCoinCount()
		if coins > collectedCoins then
			collectedCoins = coins
			updateState()
		end
	
		-- Если мешок полон — останавливаем фарм
		if collectedCoins >= maxCoins then
			print("🛑 Мешок полон! (" .. collectedCoins .. "/" .. maxCoins .. ") Останавливаем фарм...")
			stopFarm()
			return
		end
	
		-- Задержка между телепортами
		local now = tick()
		if now - lastTeleportTime < 1.5 then
			return
		end
		lastTeleportTime = now
	
		local coin = findNearestCoin()
		if coin then
			teleportToCoin(coin)
			print("🪙 Телепорт к монете! (" .. collectedCoins .. "/" .. maxCoins .. ")")
		else
			print("⏳ Монет нет на карте")
		end
	end
	
	-- ===== ЗАПУСК =====
	local function startFarm()
		if isFarming then return end
		isFarming = true
		waitingForRespawn = false
		lastTeleportTime = 0
		collectedCoins = getCoinCount()
	
		farmLoop = runService.Heartbeat:Connect(function()
			if not isEnabled then
				stopFarm()
				return
			end
			farmLoopFunction()
		end)
	
		print("🪙 Авто-фарм запущен! Лимит: " .. maxCoins .. " монет")
		updateState()
	end
	
	-- ===== ОСТАНОВКА =====
	local function stopFarm()
		isFarming = false
		waitingForRespawn = false
		if farmLoop then
			farmLoop:Disconnect()
			farmLoop = nil
		end
		print("🪙 Авто-фарм остановлен! Собрано: " .. collectedCoins .. " монет")
		updateState()
	end
	
	-- ===== ПЕРЕКЛЮЧЕНИЕ =====
	local function toggleFarm()
		isEnabled = not isEnabled
		updateState()
	
		if isEnabled then
			startFarm()
		else
			stopFarm()
		end
	end
	
	button.MouseButton1Click:Connect(toggleFarm)
	
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		if isEnabled and waitingForRespawn then
			waitingForRespawn = false
			updateState()
			print("🔄 Переродился! Продолжаем фарм...")
		end
	end)
	
	updateState()
	print("✅ MM2_AutoFarm загружена (с остановкой по лимиту)!")
end;
