		else
			print("🔫 Rapid Fire включён! Зажми ЛКМ для стрельбы.")
		end
	end
	
	button.MouseButton1Click:Connect(toggleRapidFire)
	
	-- ===== ОСТАНОВКА ПРИ СМЕРТИ =====
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		if isEnabled then
			stopFiring()
		end
	end)
	
