local function C_c()
local script = G2L["c"];
	-- ==========================================
	-- ПЕРЕТАСКИВАНИЕ (ПЛАВНОЕ + РЕЗКОЕ)
	-- ==========================================
	local frame = script.Parent
	local uis = game:GetService("UserInputService")
	
	local dragging = false
	local dragStart = nil
	local startPos = nil
	local connection = nil
	
	local function startDrag(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
	
			-- Отключаем стандартное поведение
			if connection then
				connection:Disconnect()
				connection = nil
			end
	
			connection = uis.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					local delta = input.Position - dragStart
					frame.Position = UDim2.new(
						startPos.X.Scale,
						startPos.X.Offset + delta.X,
						startPos.Y.Scale,
						startPos.Y.Offset + delta.Y
					)
				end
			end)
		end
	end
	
	local function endDrag(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			if connection then
				connection:Disconnect()
				connection = nil
			end
		end
	end
	
	-- Подключаем события
	frame.InputBegan:Connect(startDrag)
	uis.InputEnded:Connect(endDrag)
	
	-- Для сенсорных экранов
	frame.TouchBegan:Connect(function(input)
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end)
	
	frame.TouchMoved:Connect(function(input)
		if dragging then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
	
	frame.TouchEnded:Connect(function()
		dragging = false
	end)
	
	print("✅ Перетаскивание обновлено!")
end;
