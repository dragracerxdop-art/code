local function C_c1()
local script = G2L["c1"];
	-- ==========================================
	-- ОПТИМИЗИРОВАННЫЙ ESP (БЕЗ ЛАГОВ)
	-- ==========================================
	local player = game.Players.LocalPlayer
	local runService = game:GetService("RunService")
	
	local highlights = {}
	local espEnabled = false
	local espColor = Color3.fromRGB(255, 0, 0)
	
	-- Функция создания подсветки
	local function createHighlight(char)
		if not char then return nil end
		local highlight = Instance.new("Highlight")
		highlight.FillColor = espColor
		highlight.FillTransparency = 0.3
		highlight.OutlineColor = espColor
		highlight.OutlineTransparency = 0
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Adornee = char
		highlight.Name = "ESP_Highlight"
		highlight.Parent = char
		return highlight
	end
	
	-- Полная очистка
	local function clearESP()
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("Highlight") and obj.Name == "ESP_Highlight" then
				obj:Destroy()
			end
		end
		highlights = {}
	end
	
	-- Обновление ESP (только если включён)
	local function updateESP()
		if not espEnabled then
			clearESP()
			return
		end
	
		-- Проверяем только живых игроков
		local activePlayers = {}
		for _, plr in pairs(game.Players:GetPlayers()) do
			if plr ~= player and plr.Character and plr.Character:FindFirstChild("Humanoid") then
				activePlayers[plr] = true
			end
		end
	
		-- Удаляем подсветку для мёртвых/вышедших
		for plr, highlight in pairs(highlights) do
			if not activePlayers[plr] then
				if highlight and highlight.Parent then
					highlight:Destroy()
				end
				highlights[plr] = nil
			end
		end
	
		-- Создаём подсветку для новых игроков
		for plr, _ in pairs(activePlayers) do
			if not highlights[plr] then
				local h = createHighlight(plr.Character)
				if h then
					highlights[plr] = h
				end
			end
		end
	end
	
	-- Обновляем состояние ESP (вызывается из кнопок)
	local function checkESPState()
		local newState = _G.ESP and _G.ESP.BoxEnabled or false
		local newColor = _G.ESP and _G.ESP.BoxColor or Color3.fromRGB(255, 0, 0)
	
		if newState ~= espEnabled or newColor ~= espColor then
			espEnabled = newState
			espColor = newColor
	
			-- Если выключили — сразу чистим
			if not espEnabled then
				clearESP()
			end
	
			-- Обновляем цвета у существующих подсветок
			for _, h in pairs(highlights) do
				if h and h.Parent then
					h.FillColor = espColor
					h.OutlineColor = espColor
				end
			end
		end
	end
	
	-- Проверяем состояние раз в 2 секунды (не грузит)
	game:GetService("RunService").Heartbeat:Connect(function()
		checkESPState()
	end)
	
	-- Обновляем позиции раз в 3 кадра (только если включён)
	local frameCounter = 0
	runService.RenderStepped:Connect(function()
		if not espEnabled then return end
	
		frameCounter = frameCounter + 1
		if frameCounter % 3 == 0 then
			updateESP()
		end
	end)
	
	-- Очистка при выходе игроков
	game.Players.PlayerRemoving:Connect(function(plr)
		if highlights[plr] then
			if highlights[plr].Parent then
				highlights[plr]:Destroy()
			end
			highlights[plr] = nil
		end
	end)
	
	print("✅ Оптимизированный ESP загружен!")
end;
