local function C_c2()
local script = G2L["c2"];
	-- ==========================================
	-- АНТИ-ФЛИНГ (ОТКЛЮЧЕНИЕ СТОЛКНОВЕНИЙ)
	-- ==========================================
	local player = game.Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	
	local antiFlingEnabled = false
	local originalCollisions = {}  -- храним оригинальные настройки
	
	-- Функция: отключить столкновения со всеми игроками
	local function disableCollisions()
		local char = player.Character
		if not char then return end
	
		for _, part in pairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				-- Сохраняем оригинальное состояние
				originalCollisions[part] = part.CanCollide
				-- Отключаем столкновения
				part.CanCollide = false
			end
		end
		print("🛡️ Анти-флинг ВКЛЮЧЕН (столкновения отключены)")
	end
	
	-- Функция: вернуть столкновения обратно
	local function enableCollisions()
		local char = player.Character
		if not char then return end
	
		for part, canCollide in pairs(originalCollisions) do
			if part and part.Parent then
				part.CanCollide = canCollide
			end
		end
		originalCollisions = {}
		print("🛡️ Анти-флинг ВЫКЛЮЧЕН (столкновения восстановлены)")
	end
	
	-- Функция переключения
	local function toggleAntiFling()
		antiFlingEnabled = not antiFlingEnabled
	
		if antiFlingEnabled then
			disableCollisions()
		else
			enableCollisions()
		end
	end
	
	-- ===== ПРИМЕР: ПОДКЛЮЧЕНИЕ К КНОПКЕ =====
	-- Если хочешь привязать к кнопке в MISC:
	local button = script.Parent  -- если скрипт внутри кнопки
	button.MouseButton1Click:Connect(function()
		toggleAntiFling()
	end)
	
	-- ИЛИ если хочешь просто включить по команде в консоли:
	-- _G.toggleAntiFling = toggleAntiFling
	
	-- ===== АВТОМАТИЧЕСКОЕ ВОССТАНОВЛЕНИЕ ПРИ ПЕРЕРОЖДЕНИИ =====
	player.CharacterAdded:Connect(function(char)
		task.wait(1)  -- ждём загрузки персонажа
		if antiFlingEnabled then
			disableCollisions()
		end
	end)
	
	print("✅ Анти-флинг загружен! Используй toggleAntiFling()")
end;
