-- ==========================================
-- СВИТЧ ТАБС (УПРОЩЕННАЯ ВЕРСИЯ)
-- ==========================================
local leftFrame = script.Parent
local main = leftFrame.Parent
local rightFrame = main:FindFirstChild("RightFrame")

if not rightFrame then
    warn("❌ RightFrame не найден!")
    return
end

-- ===== ФУНКЦИЯ ПЕРЕКЛЮЧЕНИЯ =====
local function switchTab(tabName)
    print("🔘 Переключение на: " .. tabName)

    -- Скрываем ВСЁ
    for _, child in pairs(rightFrame:GetChildren()) do
        child.Visible = false
    end

    -- ===== TELEPORT =====
    if tabName == "TELEPORT" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and child.Name == "TELEPORT_ToggleList" then
                child.Visible = true
            end
            if child:IsA("TextButton") and child.Name == "TELEPORT_ADD" then
                child.Visible = true
            end
            if child:IsA("TextButton") and child.Name == "TELEPORT_REMOVE" then
                child.Visible = true
            end
            if child:IsA("TextBox") and child.Name == "TELEPORT_NAME" then
                child.Visible = true
            end
            if child:IsA("ScrollingFrame") and child.Name == "TELEPORT_SCROLL" then
                child.Visible = true
            end
        end
        print("✅ TELEPORT")

    -- ===== ESP =====
    elseif tabName == "ESP" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "ESP_Box" or
                child.Name == "ESP_Box_Color" or
                child.Name == "ESP_Name"
            ) then
                child.Visible = true
            end
        end
        print("✅ ESP")

    -- ===== SPECTATE =====
    elseif tabName == "SPECTATE" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "SPECTATE_OpenList" or
                child.Name == "SPECTATE_Start"
            ) then
                child.Visible = true
            end
        end
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("TextBox") and string.find(child.Name, "SPECTATE_") then
                child.Visible = true
            end
            if child:IsA("TextLabel") and string.find(child.Name, "SPECTATE_") then
                child.Visible = true
            end
        end
        print("✅ SPECTATE")

    -- ===== MISC =====
    elseif tabName == "MISC" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "MISC_OpenPlayerList" or
                child.Name == "MISC_Fling" or
                child.Name == "MISC_AntiFling" or
                child.Name == "MISC_Hitbox" or
                child.Name == "MISC_CTRL_DEL" or
                child.Name == "MISC_CTRL_CLICK" or
                child.Name == "MISC_WhiteList_Open" or
                child.Name == "MISC_Fly" or
                child.Name == "MISC_Rejoin" or
                child.Name == "MISC_FullBright"
            ) then
                child.Visible = true
            end
        end
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("TextBox") and (child.Name == "MISC_HitboxValue" or child.Name == "MISC_FlySpeed") then
                child.Visible = true
            end
        end
        print("✅ MISC")

    -- ===== MM2 =====
    elseif tabName == "MM2" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "MM2_CheckRoles" or
                child.Name == "MM2_ESP" or
                child.Name == "MM2_GunESP" or
                child.Name == "MM2_PickUpGun" or
                child.Name == "MM2_AutoFarm"
            ) then
                child.Visible = true
            end
            if child:IsA("Frame") and child.Name == "MM2_Roles" then
                child.Visible = false
            end
        end
        print("✅ MM2")

    -- ===== DA HOOD =====
    elseif tabName == "Da Hood" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "DaHood_AutoFarm" or
                child.Name == "DaHood_RapidFire"
            ) then
                child.Visible = true
            end
        end
        print("✅ DA HOOD")

    -- ===== TROLL =====
    elseif tabName == "Troll" then
        for _, child in pairs(rightFrame:GetChildren()) do
            if child:IsA("ImageButton") and (
                child.Name == "TROLL_Dropkick" or
                child.Name == "TROLL_TennaKick" or
                child.Name == "TROLL_MMAKick" or
                child.Name == "TROLL_Slap" or
                child.Name == "TROLL_Slap2" or
                child.Name == "TROLL_Push" or
                child.Name == "TROLL_Push2"
            ) then
                child.Visible = true
            end
        end
        print("✅ TROLL")

    -- ===== INFO =====
    elseif tabName == "INFO" then
        print("✅ INFO")
    else
        print("❌ Неизвестная вкладка: " .. tabName)
    end
end

-- ===== ПОДКЛЮЧАЕМ КНОПКИ =====
for _, btn in pairs(leftFrame:GetChildren()) do
    if btn:IsA("ImageButton") then
        btn.MouseButton1Click:Connect(function()
            switchTab(btn.Name)
        end)
    end
end

-- Первая вкладка
switchTab("TELEPORT")
print("✅ Свитч табс загружен!")
