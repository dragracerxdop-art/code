local function C_4b()
local script = G2L["4b"];
	-- ==========================================
	-- MISC_AntiFling (ВКЛ/ВЫКЛ)
	-- ==========================================
	local button = script.Parent
	local player = game.Players.LocalPlayer
	local runService = game:GetService("RunService")
	
	local isEnabled = false
	local antiFlingLoop = nil
	local connections = {}
	
	-- Индикатор
	local indicator = Instance.new("TextLabel")
	indicator.Name = "Indicator"
	indicator.Size = UDim2.new(1, 0, 0.3, 0)
	indicator.Position = UDim2.new(0, 0, 0.7, 0)
	indicator.BackgroundTransparency = 1
	indicator.Text = "ВЫКЛ"
	indicator.TextColor3 = Color3.fromRGB(255, 0, 0)
	indicator.TextSize = 14
	indicator.Font = Enum.Font.SourceSansBold
	indicator.Parent = button
	
	local function updateState()
		if isEnabled then
			indicator.Text = "ВКЛ"
			indicator.TextColor3 = Color3.fromRGB(0, 255, 0)
		else
			indicator.Text = "ВЫКЛ"
			indicator.TextColor3 = Color3.fromRGB(255, 0, 0)
		end
	end
	
	-- ===== ОТКЛЮЧЕНИЕ КОЛЛИЗИЙ У ВСЕХ ИГРОКОВ =====
	local function setupCharacterCollision(character)
		local function disableCollide(part)
			if isEnabled and part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	
		for _, part in ipairs(character:GetChildren()) do
			disableCollide(part)
		end
	
		local childAddedConn = character.ChildAdded:Connect(disableCollide)
	
		local steppedConn = runService.Stepped:Connect(function()
			if isEnabled and character:IsDescendantOf(workspace) then
				for _, part in ipairs(character:GetChildren()) do
					if part:IsA("BasePart") and part.CanCollide then
						part.CanCollide = false
					end
				end
			end
		end)
	
		character.Destroying:Connect(function()
			childAddedConn:Disconnect()
			steppedConn:Disconnect()
		end)
	end
	
	local function trackPlayer(plr)
		if plr == player then return end
		local charAddedConn = plr.CharacterAdded:Connect(setupCharacterCollision)
		if plr.Character then
			setupCharacterCollision(plr.Character)
		end
		connections[plr] = charAddedConn
	end
	
	local function untrackPlayer(plr)
		if connections[plr] then
			connections[plr]:Disconnect()
			connections[plr] = nil
		end
	end
	
	-- ===== ВКЛЮЧЕНИЕ =====
	local function enableAntiFling()
		for _, plr in ipairs(game.Players:GetPlayers()) do
			trackPlayer(plr)
		end
		game.Players.PlayerAdded:Connect(trackPlayer)
		game.Players.PlayerRemoving:Connect(untrackPlayer)
	end
	
	-- ===== ВЫКЛЮЧЕНИЕ (ВОССТАНОВЛЕНИЕ КОЛЛИЗИЙ) =====
	local function disableAntiFling()
		for plr, conn in pairs(connections) do
			conn:Disconnect()
			connections[plr] = nil
		end
		-- Восстанавливаем коллизии у всех игроков
		for _, plr in pairs(game.Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				for _, part in pairs(plr.Character:GetChildren()) do
					if part:IsA("BasePart") then
						part.CanCollide = true
					end
				end
			end
		end
	end
	
	-- ===== ПЕРЕКЛЮЧЕНИЕ =====
	local function toggleAntiFling()
		isEnabled = not isEnabled
		updateState()
	
		if isEnabled then
			enableAntiFling()
			print("🛡️ Анти-флинг ВКЛЮЧЕН")
		else
			disableAntiFling()
			print("🛡️ Анти-флинг ВЫКЛЮЧЕН")
		end
	end
	
	button.MouseButton1Click:Connect(toggleAntiFling)
	
	updateState()
	print("✅ MISC_AntiFling загружена!")
end;
