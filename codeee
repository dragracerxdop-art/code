local function C_c0()
local script = G2L["c0"];
	-- ==========================================
	-- ГОРЯЧИЕ КЛАВИШИ (Ctrl + ЛКМ)
	-- ==========================================
	local player = game.Players.LocalPlayer
	local uis = game:GetService("UserInputService")
	local mouse = player:GetMouse()
	
	-- ===== ФУНКЦИЯ: УДАЛЕНИЕ ОБЪЕКТА ПОД КУРСОРОМ =====
	local function deleteTarget()
		local target = mouse.Target
	
		if not target then
			print("❌ Нет объекта под курсором!")
			return
		end
	
		-- Проверяем, что это не игрок
		local isPlayerPart = false
		for _, plr in pairs(game.Players:GetPlayers()) do
			if plr.Character and target:IsDescendantOf(plr.Character) then
				isPlayerPart = true
				break
			end
		end
	
		if isPlayerPart then
			print("❌ Нельзя удалить игрока!")
			return
		end
	
		if target and target:IsA("BasePart") then
			local name = target.Name
			target:Destroy()
			print("✅ Удалён объект: " .. name)
		else
			print("❌ Это не объект для удаления")
		end
	end
	
	-- ===== ФУНКЦИЯ: ТЕЛЕПОРТ В ТОЧКУ КЛИКА =====
	local function teleportToClick()
		local target = mouse.Target
		local hitPoint = mouse.Hit  -- точка куда кликнул
	
		if not target then
			print("❌ Нет объекта под курсором!")
			return
		end
	
		local char = player.Character
		if not char then
			print("❌ Персонаж не найден!")
			return
		end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then
			print("❌ HumanoidRootPart не найден!")
			return
		end
	
		-- Телепорт ровно в точку клика
		local pos = hitPoint.Position
		hrp.CFrame = CFrame.new(pos.X, pos.Y + 3, pos.Z)
	
		print("✅ Телепорт в точку: X=" .. math.round(pos.X) .. " Y=" .. math.round(pos.Y + 3) .. " Z=" .. math.round(pos.Z))
	end
	
	-- ===== ОТСЛЕЖИВАЕМ КЛИК МЫШИ С ЗАЖАТЫМ CTRL =====
	uis.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
	
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			local ctrlPressed = uis:IsKeyDown(Enum.KeyCode.LeftControl) or uis:IsKeyDown(Enum.KeyCode.RightControl)
	
			if ctrlPressed then
				if _G.Misc and _G.Misc.CtrlDel then
					task.wait(0.05)
					deleteTarget()
				elseif _G.Misc and _G.Misc.CtrlClick then
					task.wait(0.05)
					teleportToClick()
				else
					print("⚠️ Ни одна функция не включена в меню MISC")
				end
			end
		end
	end)
	
	print("✅ Горячие клавиши загружены!")
	print("   Ctrl + ЛКМ → удаление (CTRL+DEL)")
	print("   Ctrl + ЛКМ → телепорт в точку клика (CTRL+CLICK)")
end;
