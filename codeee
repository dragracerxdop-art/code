-- ==========================================
-- ТЕЛЕПОРТЫ (СКРОЛЛ ВСЕГДА АКТИВЕН)
-- ==========================================
local player = game.Players.LocalPlayer
local rightFrame = script.Parent

print("🚀 TeleportManager запущен!")

local teleportScroll = rightFrame:FindFirstChild("TELEPORT_SCROLL")
local inputBox = rightFrame:FindFirstChild("TELEPORT_NAME")
local addBtn = rightFrame:FindFirstChild("TELEPORT_ADD")
local removeBtn = rightFrame:FindFirstChild("TELEPORT_REMOVE")
local template = teleportScroll and teleportScroll:FindFirstChild("TELEPORT_TEMPLATE")

if not teleportScroll or not inputBox or not addBtn or not removeBtn or not template then
    warn("❌ Не все элементы найдены!")
    return
end

print("✅ Все элементы найдены!")

template.Visible = false
_G.Teleports = _G.Teleports or {}
local selectedName = nil

-- ===== ОБНОВЛЕНИЕ СПИСКА =====
local function updateList()
    -- Удаляем старые кнопки (кроме шаблона)
    for _, child in pairs(teleportScroll:GetChildren()) do
        if child:IsA("TextButton") and child ~= template then
            child:Destroy()
        end
        if child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    local yOffset = template.Position.Y.Offset
    local buttonHeight = 45

    -- Создаём кнопки для телепортов
    for name, pos in pairs(_G.Teleports) do
        local btn = template:Clone()
        btn.Visible = true
        btn.Text = name
        btn.Position = UDim2.new(template.Position.X.Scale, template.Position.X.Offset, 0, yOffset)
        btn.Parent = teleportScroll
        yOffset = yOffset + buttonHeight

        -- 👇 ПРИНУДИТЕЛЬНО СТАВИМ ШРИФТ MICROMA
        btn.FontFace = Font.new("rbxasset://fonts/families/Michroma.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
        btn.TextSize = 14

        btn.MouseButton1Click:Connect(function()
            for _, child in pairs(teleportScroll:GetChildren()) do
                if child:IsA("TextButton") and child ~= template then
                    child.BackgroundColor3 = template.BackgroundColor3
                    child.BackgroundTransparency = template.BackgroundTransparency
                end
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 0, 255)
            btn.BackgroundTransparency = 0.3
            selectedName = name
            print("✅ Выбран телепорт: " .. name)
        end)

        btn.MouseButton2Click:Connect(function()
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = pos
                print("✅ Телепорт к: " .. name)
            else
                print("❌ Персонаж не найден!")
            end
        end)
    end

    -- 👇 СКРОЛЛ ВСЕГДА АКТИВЕН (минимальная высота 400)
    local minCanvasHeight = 400
    local canvasHeight = math.max(yOffset + 10, minCanvasHeight)
    teleportScroll.CanvasSize = UDim2.new(0, 0, 0, canvasHeight)

    print("✅ Список обновлён! CanvasSize: " .. canvasHeight)
end

-- ===== КНОПКА + =====
addBtn.MouseButton1Click:Connect(function()
    local name = inputBox.Text
    if name == "" then
        print("❌ Введите название!")
        return
    end

    local char = player.Character
    if not char then
        print("❌ Персонаж не найден!")
        return
    end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        print("❌ HumanoidRootPart не найден!")
        return
    end

    _G.Teleports[name] = hrp.CFrame
    inputBox.Text = ""
    updateList()
    print("✅ Сохранён телепорт: " .. name)
end)

-- ===== КНОПКА - =====
removeBtn.MouseButton1Click:Connect(function()
    if not selectedName then
        print("❌ Сначала выбери телепорт (кликни по нему)!")
        return
    end

    if _G.Teleports[selectedName] == nil then
        print("❌ Телепорт уже удалён!")
        selectedName = nil
        return
    end

    _G.Teleports[selectedName] = nil
    selectedName = nil
    updateList()
    print("❌ Удалён выбранный телепорт!")
end)

-- ===== ПЕРВОЕ ОБНОВЛЕНИЕ =====
updateList()

print("✅ TeleportManager загружен!")
